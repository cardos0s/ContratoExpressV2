@page "/"
@inject ContractService ContractSvc
@inject NavigationManager Nav

<PageTitle>ContratoExpress — Gere Contratos Profissionais em 2 Minutos</PageTitle>

<div class="landing">

    <!-- ═══ HEADER ═══ -->
    <header class="app-header">
        <div class="logo">
            <div class="logo-icon">C</div>
            <span class="logo-text">Contrato<span class="accent">Express</span></span>
        </div>
        <a href="#pricing" class="header-cta">Gerar meu contrato</a>
    </header>

    <!-- ═══ HERO ═══ -->
    <div class="hero-section">
        <div class="hero-badge"> +2.000 contratos gerados</div>
        <h1 class="hero-h1">
            Vai começar um serviço<br/><span class="hero-highlight">sem contrato?</span>
        </h1>
        <p class="hero-sub">
            Você pode perder dinheiro com cliente caloteiro.<br/>
            Crie um contrato profissional em <strong>2 minutos</strong> e se proteja.
        </p>
        <div class="hero-proof">
            <span class="proof-warning">Um único cliente sem contrato pode te dar prejuízo de R$1.000+</span>
            <span class="proof-price"> A partir de <strong>R$7,90</strong></span>
        </div>
        <a href="#documentos" class="cta-primary">
             Gerar meu contrato agora
        </a>
        <p class="hero-micro">Sem cadastro para visualizar • Pagamento só na hora de baixar</p>
    </div>

    <!-- ═══ CONTRACT DOCK ═══ -->
    <div class="dock-section">
        <div class="dock-label left"> Nossos Contratos</div>
        <div class="contract-dock">
            @foreach (var type in contractTypes.Take(10))
            {
                <div class="dock-icon" style="--icon-accent: @type.AccentColor"
                     title="@type.Title"
                     @onclick="() => NavigateToContract(type.Id)">
                    @if (!string.IsNullOrEmpty(type.ImageUrl))
                    {
                        <img src="@type.ImageUrl" alt="@type.Title" class="dock-img" />
                    }
                    else
                    {
                        <span class="dock-emoji">@type.Icon</span>
                    }
                    <div class="dock-tooltip">@type.Title</div>
                </div>
            }
        </div>
        <div class="dock-label right">Clique para ver →</div>
    </div>

    <!-- ═══ VALOR ═══ -->
    <div class="value-section" id="valor">
        <h2 class="section-title"> Por que usar o ContratoExpress?</h2>
        <div class="value-grid">
            <div class="value-card">
                <div class="value-icon">🛡️</div>
                <h3>Evite cliente caloteiro</h3>
                <p>Contrato com cláusulas de multa por inadimplência e atraso. Proteção real pro seu trabalho.</p>
            </div>
            <div class="value-card">
                <div class="value-icon">⚖️</div>
                <h3>Cláusulas de proteção</h3>
                <p>Multa por rescisão, juros de mora, propriedade intelectual, confidencialidade — tudo incluso.</p>
            </div>
            <div class="value-card">
                <div class="value-icon">⚡</div>
                <h3>Pronto em 2 minutos</h3>
                <p>Preenche os dados, gera o PDF. Sem enrolação, sem precisar de advogado pra um contrato simples.</p>
            </div>
            <div class="value-card">
                <div class="value-icon">📝</div>
                <h3>Linguagem profissional</h3>
                <p>Texto jurídico com referências ao Código Civil, Lei do Inquilinato e LGPD. Parece feito por advogado.</p>
            </div>
        </div>
    </div>

    <!-- ═══ MAC WINDOW PREVIEW ═══ -->
    <div class="mac-preview-section">
        <h2 class="section-title"> Veja como fica seu contrato</h2>
        <p class="section-sub">Clique nas seções para explorar cada parte do documento.</p>
        <div class="mac-window">
            <div class="mac-titlebar">
                <div class="mac-dots">
                    <span class="mac-dot red"></span>
                    <span class="mac-dot yellow"></span>
                    <span class="mac-dot green"></span>
                </div>
                <div class="mac-title">ContratoExpress — Prestação de Serviço</div>
                <div class="mac-dots" style="visibility:hidden">
                    <span class="mac-dot"></span><span class="mac-dot"></span><span class="mac-dot"></span>
                </div>
            </div>
            <div class="mac-content">
                <div class="mac-sidebar">
                    @foreach (var tab in macTabs)
                    {
                        <div class="mac-sidebar-item @(activeMacTab == tab.Key ? "active" : "")"
                             @onclick="() => activeMacTab = tab.Key">
                            @tab.Value.Icon @tab.Value.Label
                        </div>
                    }
                </div>
                <div class="mac-editor">
                    <div class="mac-typing-area" @key="activeMacTab">
                        @foreach (var line in macTabs[activeMacTab].Lines)
                        {
                            <div class="typing-line @line.Css">@line.Text@if (line.Cursor) {<span class="typing-cursor">|</span>}</div>
                        }
                    </div>
                    <div class="mac-statusbar">
                        <span>📄 16 cláusulas</span>
                        <span>✍️ 2 testemunhas</span>
                        <span>⚖️ Foro definido</span>
                        <span class="status-badge">✅ LGPD</span>
                    </div>
                </div>
            </div>
        </div>
        <a href="#documentos" class="cta-primary small mac-cta"> Gerar meu contrato</a>
    </div>

    <!-- ═══ DOCUMENTOS ═══ -->
    <div class="docs-section" id="documentos">
        <h2 class="section-title"> Qual tipo de contrato você precisa agora?</h2>
        <p class="section-sub">Escolha a categoria e gere em poucos minutos.</p>

        <!-- Category Tabs -->
        <div class="category-tabs">
            @foreach (var cat in categories)
            {
                var count = cat.Key == "Todos"
                    ? contractTypes.Count
                    : contractTypes.Count(c => c.Category == cat.Key);
                <button class="category-tab @(selectedCategory == cat.Key ? "active" : "")"
                        @onclick="() => SelectCategory(cat.Key)">
                    <span class="category-tab-icon">@cat.Value</span>
                    <span class="category-tab-label">@cat.Key</span>
                    <span class="category-badge">@count</span>
                </button>
            }
        </div>

        <!-- Contract Cards -->
        <div class="docs-grid">
            @foreach (var type in filteredContracts)
            {
                <div class="doc-card" @onclick="() => NavigateToContract(type.Id)"
                     style="--card-accent: @type.AccentColor">
                    <div class="doc-card-icon">
                        @if (!string.IsNullOrEmpty(type.ImageUrl))
                        {
                            <img src="@type.ImageUrl" alt="@type.Title" class="doc-card-img" />
                        }
                        else
                        {
                            @type.Icon
                        }
                    </div>
                    <div class="doc-card-body">
                        <h3>@type.Title</h3>
                        <p>@type.Description</p>
                    </div>
                    <div class="doc-card-meta">
                        <span class="doc-card-category">@type.Category</span>
                        <span class="doc-card-arrow">→</span>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- ═══ COMO FUNCIONA ═══ -->
    <div class="how-section">
        <h2 class="section-title"> Como funciona</h2>
        <div class="how-steps">
            <div class="how-step">
                <div class="step-circle">1</div>
                <h3>Escolha o tipo de contrato</h3>
                <p>Selecione o modelo ideal para sua situação</p>
            </div>
            <div class="how-step">
                <div class="step-circle">2</div>
                <h3>Preencha em minutos</h3>
                <p>Responda algumas perguntas simples sobre as partes e condições</p>
            </div>
            <div class="how-step">
                <div class="step-circle accent">3</div>
                <h3>Gere e use</h3>
                <p>Seu contrato profissional pronto para proteger seu trabalho</p>
            </div>
        </div>
    </div>

    <!-- ═══ PRICING ═══ -->
    <div class="pricing-section" id="pricing">
        <h2 class="section-title"> Escolha seu plano</h2>
        <p class="section-sub">Pague uma vez, use quando quiser. Sem assinatura.</p>
        <div class="pricing-grid">
            <div class="price-card">
                <div class="price-label">Básico</div>
                <div class="price-value">R$ 7,90</div>
                <ul class="price-features">
                    <li>✔ 1 contrato profissional</li>
                    <li>✔ PDF pronto pra imprimir</li>
                    <li>✔ Cláusulas de proteção</li>
                </ul>
                <a href="#documentos" class="price-btn outline">Escolher</a>
            </div>
            <div class="price-card popular">
                <div class="price-badge"> MAIS POPULAR</div>
                <div class="price-label">Profissional</div>
                <div class="price-value">R$ 9,90</div>
                <ul class="price-features">
                    <li>✔ <strong>3 contratos</strong> profissionais</li>
                    <li>✔ Melhor custo-benefício</li>
                    <li>✔ PDF pronto pra imprimir</li>
                    <li>✔ Todas as cláusulas de proteção</li>
                </ul>
                <a href="#documentos" class="price-btn solid"> Escolher este</a>
            </div>
            <div class="price-card">
                <div class="price-label">Avançado</div>
                <div class="price-value">R$ 19,90</div>
                <ul class="price-features">
                    <li>✔ <strong>10 contratos</strong> profissionais</li>
                    <li>✔ Ideal pra quem usa sempre</li>
                    <li>✔ PDF pronto pra imprimir</li>
                    <li>✔ Todas as cláusulas de proteção</li>
                </ul>
                <a href="#documentos" class="price-btn outline">Escolher</a>
            </div>
        </div>
    </div>

    <!-- ═══ OBJEÇÃO ═══ -->
    <div class="objection-section">
        <div class="objection-card">
            <span class="objection-icon">⚠️</span>
            <div>
                <strong>Importante:</strong> Este gerador não substitui um advogado, mas fornece um modelo profissional pronto para uso, com linguagem jurídica e referências legais. Ideal para freelancers, autônomos e pequenos negócios que precisam de proteção básica sem gastar com honorários advocatícios.
            </div>
        </div>
    </div>

    <!-- ═══ CTA FINAL ═══ -->
    <div class="final-cta">
        <h2>Não arrisque trabalhar<br/><span class="hero-highlight">sem contrato.</span></h2>
        <p>Proteja seu trabalho e seu dinheiro em 2 minutos.</p>
        <a href="#documentos" class="cta-primary"> Gerar meu contrato agora</a>
    </div>

    <!-- ═══ FOOTER ═══ -->
    <footer class="landing-footer">
        <div class="footer-brand">
            <div class="logo-icon small">C</div>
            <span>ContratoExpress</span>
        </div>
        <p>© @DateTime.Now.Year — Este gerador não substitui assessoria jurídica profissional.</p>
    </footer>

</div>

@code {
    private List<ContractType> contractTypes = new();
    private string selectedCategory = "TI";

    private static readonly Dictionary<string, string> categories = new()
    {
        { "Todos", "📋" },
        { "TI", "💻" },
        { "Direito", "⚖️" },
        { "Saúde", "🏥" },
        { "Contábil", "📊" },
        { "Geral", "📂" },
    };

    private IEnumerable<ContractType> filteredContracts =>
        selectedCategory == "Todos"
            ? contractTypes
            : contractTypes.Where(c => c.Category == selectedCategory);

    protected override void OnInitialized()
    {
        contractTypes = ContractSvc.GetContractTypes();
    }

    private void SelectCategory(string category)
    {
        selectedCategory = category;
    }

    private void NavigateToContract(string id) => Nav.NavigateTo($"/contrato/{id}");

    // ═══ Mac Window Interactive Tabs ═══
