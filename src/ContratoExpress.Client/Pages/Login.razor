@page "/login"
@inject AuthService Auth
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Entrar — ContratoExpress</PageTitle>

<div class="form-container">
    <header class="app-header">
        <div class="logo" @onclick='() => Nav.NavigateTo("/")'>         
            <div class="logo-icon">C</div>
            <span class="logo-text">Contrato<span class="accent">Express</span></span>
        </div>
    </header>

    <div class="auth-page">
        <div class="auth-card">
            <h2 class="auth-title">@(isRegister ? "Criar conta" : "Entrar")</h2>
            <p class="auth-desc">@(isRegister ? "Crie sua conta gratuita para gerar contratos" : "Acesse sua conta para continuar")</p>

            @if (!string.IsNullOrEmpty(errorMsg))
            {
                <div class="auth-error">@errorMsg</div>
            }

            @if (isRegister)
            {
                <div class="auth-field">
                    <label class="field-label">NOME (OPCIONAL)</label>
                    <input type="text" class="field-input" placeholder="Seu nome"
                           @bind="name" />
                </div>
            }

            <div class="auth-field">
                <label class="field-label">E-MAIL</label>
                <input type="email" class="field-input" placeholder="seu@email.com"
                       @bind="email" />
            </div>

            <div class="auth-field">
                <label class="field-label">SENHA</label>
                <input type="password" class="field-input" placeholder="Mínimo 6 caracteres"
                       @bind="password" />
            </div>

            <button class="btn-auth" disabled="@(loading || cooldown)" @onclick="HandleSubmit">
                @if (loading)
                {
                    <span>Aguarde...</span>
                }
                else if (cooldown)
                {
                    <span>Aguarde @cooldownSeconds s...</span>
                }
                else
                {
                    <span>@(isRegister ? "Criar conta" : "Entrar")</span>
                }
            </button>

            <p class="auth-toggle">
                @if (isRegister)
                {
                    <span>Já tem conta? </span>
                    <a @onclick="() => { isRegister = false; errorMsg = null; }" href="javascript:void(0)">Fazer login</a>
                }
                else
                {
                    <span>Não tem conta? </span>
                    <a @onclick="() => { isRegister = true; errorMsg = null; }" href="javascript:void(0)">Criar conta grátis</a>
                }
            </p>
        </div>

        <div class="auth-info">
            <div class="auth-info-item">⚡ Pacote de 3 contratos por apenas R$ 9,90 via PIX</div>
            <div class="auth-info-item">📄 4 modelos profissionais com linguagem jurídica</div>
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string? name;
    private bool isRegister;
    private bool loading;
    private string? errorMsg;
    private string? returnUrl;
    private bool cooldown;
    private int cooldownSeconds;
    private System.Threading.Timer? cooldownTimer;

    protected override void OnInitialized()
    {
        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        returnUrl = query["returnUrl"];

        if (Auth.IsLoggedIn)
            Nav.NavigateTo(returnUrl ?? "/");
    }

    private async Task HandleSubmit()
    {
        errorMsg = null;

        if (cooldown) return;

        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            errorMsg = "Preencha e-mail e senha.";
            return;
        }

        if (password.Length < 6)
        {
            errorMsg = "A senha precisa ter pelo menos 6 caracteres.";
            return;
        }

        loading = true;
        StateHasChanged();

        var (success, error) = isRegister
            ? await Auth.RegisterAsync(email, password, name)
            : await Auth.LoginAsync(email, password);

        loading = false;

        if (success)
        {
            Nav.NavigateTo(returnUrl ?? "/");
        }
        else
        {
            errorMsg = ParseErrorMessage(error);
        }

        StateHasChanged();
    }

    private string ParseErrorMessage(string? error)
    {
        if (string.IsNullOrEmpty(error))
            return "Erro desconhecido. Tente novamente.";

        // Handle rate limit errors (JSON or text)
        if (error.Contains("rate_limit", StringComparison.OrdinalIgnoreCase)
            || error.Contains("429", StringComparison.OrdinalIgnoreCase)
            || error.Contains("security purposes", StringComparison.OrdinalIgnoreCase))
        {
            StartCooldown(60);
            return "Muitas tentativas seguidas. Aguarde um minuto e tente novamente.";
        }

        // Handle common Supabase auth errors
        if (error.Contains("invalid_credentials", StringComparison.OrdinalIgnoreCase)
            || error.Contains("Invalid login", StringComparison.OrdinalIgnoreCase))
            return "E-mail ou senha incorretos.";

        if (error.Contains("already registered", StringComparison.OrdinalIgnoreCase)
            || error.Contains("already been registered", StringComparison.OrdinalIgnoreCase))
            return "Este e-mail já está cadastrado. Tente fazer login.";

        if (error.Contains("email_not_confirmed", StringComparison.OrdinalIgnoreCase))
            return "Confirme seu e-mail antes de fazer login. Verifique sua caixa de entrada e spam.";

        // If it looks like raw JSON, show a generic message
        if (error.TrimStart().StartsWith("{") || error.TrimStart().StartsWith("["))
            return "Ocorreu um erro. Tente novamente em alguns instantes.";

        return error;
    }

    private void StartCooldown(int seconds)
    {
        cooldown = true;
        cooldownSeconds = seconds;
        cooldownTimer?.Dispose();
        cooldownTimer = new System.Threading.Timer(_ =>
        {
            cooldownSeconds--;
            if (cooldownSeconds <= 0)
            {
                cooldown = false;
                cooldownTimer?.Dispose();
            }
            InvokeAsync(StateHasChanged);
        }, null, 1000, 1000);
    }

    public void Dispose()
    {
        cooldownTimer?.Dispose();
    }
}